# .envrc — autotune provider credentials, injected via direnv.
# Each value is read from ~/.secrets/<NAME> by the shell at `direnv allow`
# time; no secret value is ever stored in this file.
export OPENAI_API_KEY="$(cat ~/.secrets/OPENAI_API_KEY)"
export GEMINI_API_KEY="$(cat ~/.secrets/GEMINI_API_KEY)"
